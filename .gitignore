# Stardust OS - Global GitIgnore

# Rust & Cargo artifacts
# Ignores all 'target' directories across the workspace (Root, Kernel, Userland Apps/Drivers)
**/target/
Cargo.lock
*.ps1
# Binary OS/Kernel Artifacts
# These are generated by the build pipeline (run.ps1) and should not be tracked.
/esp/
**/initramfs.tar
*.iso
*.img
*.bin
*.elf
*.bin
*.pdb
*.exe
Orchestrator/bootloader/
Orchestrator/compiler/
Platform/

# Intermediate build files
/build/
/temp/
**/*.rs.bk
**/*.rs.autosave

# Debugging & Emulation Logs
*.log
.qemu_history
serial_output.txt

# IDE & Editor Specific Configuration
.vscode/
.idea/
*.swp
*.swo
*~

# OS Build & Assembly Artifacts
# These are generated during the OS image creation process.
userland/fs_root/
userland/marshal/src/initramfs.tar
esp/NvVars
esp/EFI/

# Operating System Junk (Windows / macOS / Linux)
.DS_Store
Thumbs.db
desktop.ini
.directory
.fuse_hidden*
.Trash-*
.nfs*
